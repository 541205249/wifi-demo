<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvWorkflowHeaderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWorkflowHeaderSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/brand_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvWorkflowHeaderDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/brand_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvWorkflowHeaderBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_brvah_tag_selected"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/brand_primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

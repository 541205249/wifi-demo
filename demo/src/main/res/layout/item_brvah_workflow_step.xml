<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tvWorkflowStepIndex"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_brvah_tag_selected"
        android:gravity="center"
        android:textColor="@color/brand_primary"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvWorkflowStepTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWorkflowStepSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/brand_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvWorkflowStepDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/brand_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvWorkflowStepState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_brvah_tag"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/brand_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>

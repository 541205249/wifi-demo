<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_workbench_surface_panel"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="18dp"
    android:paddingVertical="14dp">

    <TextView
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:text="SPH步长"
        android:textColor="@color/console_text_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSphStepMinus"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/bg_workbench_action_button"
        android:backgroundTint="@android:color/transparent"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="-"
        android:textColor="@color/console_text_dark"
        android:textSize="24sp" />

    <TextView
        android:id="@+id/tvSphStepValue"
        android:layout_width="120dp"
        android:layout_height="50dp"
        android:layout_marginStart="10dp"
        android:background="@android:color/white"
        android:gravity="center"
        android:textColor="@color/console_text_dark"
        android:textSize="20sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSphStepPlus"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_workbench_action_button"
        android:backgroundTint="@android:color/transparent"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="+"
        android:textColor="@color/console_text_dark"
        android:textSize="24sp" />

    <TextView
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="26dp"
        android:text="SPH步长(Shift)"
        android:textColor="@color/console_text_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSphShiftMinus"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/bg_workbench_action_button"
        android:backgroundTint="@android:color/transparent"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="-"
        android:textColor="@color/console_text_dark"
        android:textSize="24sp" />

    <TextView
        android:id="@+id/tvSphShiftValue"
        android:layout_width="120dp"
        android:layout_height="50dp"
        android:layout_marginStart="10dp"
        android:background="@android:color/white"
        android:gravity="center"
        android:textColor="@color/console_text_dark"
        android:textSize="20sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSphShiftPlus"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_workbench_action_button"
        android:backgroundTint="@android:color/transparent"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="+"
        android:textColor="@color/console_text_dark"
        android:textSize="24sp" />
</LinearLayout>

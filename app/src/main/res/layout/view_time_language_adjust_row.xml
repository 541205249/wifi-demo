<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tvAdjustLabel"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:textColor="@color/console_text_dark"
        android:textSize="26sp"
        android:textStyle="italic" />

    <TextView
        android:id="@+id/tvAdjustValue"
        android:layout_width="130dp"
        android:layout_height="60dp"
        android:layout_marginStart="28dp"
        android:background="@drawable/bg_time_setting_value_box"
        android:gravity="center"
        android:textColor="@color/console_text_dark"
        android:textSize="22sp" />

    <LinearLayout
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btnAdjustUp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_time_setting_adjust_button"
            android:contentDescription="@null"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_time_setting_adjust_up" />

        <ImageButton
            android:id="@+id/btnAdjustDown"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_time_setting_adjust_button"
            android:contentDescription="@null"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_time_setting_adjust_down" />
    </LinearLayout>
</LinearLayout>
